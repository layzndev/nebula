generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                  String           @id @default(uuid())
  email               String           @unique
  displayName         String?          @map("display_name")
  passwordHash        String           @map("password_hash")
  status              String           @default("active")
  // Foreign key to the corresponding Phantom Tenant. Nullable so a
  // customer can exist before they're materialized as a tenant on
  // Phantom (e.g. during signup before quota provisioning).
  phantomTenantId     String?          @map("phantom_tenant_id")
  failedLoginAttempts Int              @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?        @map("locked_until")
  lastLoginAt         DateTime?        @map("last_login_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  sessions            CustomerSession[]

  @@index([status])
  @@map("customers")
}

model CustomerSession {
  id         String    @id
  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  data       Json
  expiresAt  DateTime  @map("expires_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([expiresAt])
  @@map("customer_sessions")
}
