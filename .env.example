# Nebula — environment template. Copy to `.env` and fill in.

# --- API ---
NODE_ENV=development
HOST=127.0.0.1
PORT=4300
WEB_ORIGIN=http://localhost:3001
CORS_ORIGINS=http://localhost:3001
COOKIE_SAMESITE=lax
SESSION_SECRET=change-me-to-32-bytes-random-please

# Postgres dedicated to Nebula (separate from Phantom).
DATABASE_URL=postgres://nebula:nebula@localhost:5433/nebula

# Phantom platform API — token minted in the Phantom panel
# (Settings → Platform tokens). Stored in Phantom as SHA-256 hash.
PHANTOM_API_BASE_URL=http://localhost:4200
PHANTOM_PLATFORM_TOKEN=phs_live_replace_me

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4300

# --- Stripe (later, for billing) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
